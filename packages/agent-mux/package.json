{
  "name": "@a5c-ai/agent-mux",
  "version": "0.3.0",
  "type": "module",
  "license": "MIT",
  "description": "Unified dispatch layer for local CLI-based AI coding agents",
  "author": "a5c-ai",
  "homepage": "https://github.com/a5c-ai/agent-mux#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/agent-mux.git",
    "directory": "packages/agent-mux"
  },
  "bugs": {
    "url": "https://github.com/a5c-ai/agent-mux/issues"
  },
  "keywords": [
    "agent-mux",
    "amux",
    "claude",
    "codex",
    "coding-agent",
    "llm",
    "ai",
    "sdk"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "amux": "./dist/bin/amux.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@a5c-ai/agent-mux-core": "0.3.0",
    "@a5c-ai/agent-mux-adapters": "0.3.0",
    "@a5c-ai/agent-mux-cli": "0.3.0"
  }
}
