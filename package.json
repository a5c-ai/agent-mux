{
  "name": "@a5c-ai/agent-mux-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.9.0"
  },
  "workspaces": [
    "packages/core",
    "packages/adapters",
    "packages/cli",
    "packages/agent-mux",
    "packages/gateway",
    "packages/ui",
    "packages/mobile-ios-app",
    "packages/mobile-android-app",
    "packages/webui",
    "packages/harness-mock",
    "packages/tui",
    "packages/observability"
  ],
  "scripts": {
    "build": "tsc --build && npm run build:webui --silent",
    "build:webui": "npm --workspace @a5c-ai/agent-mux-webui run build",
    "typecheck": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:browser:real": "npm run build --silent && playwright test --config playwright.real.config.mjs",
    "test:coverage": "vitest run --coverage",
    "clean": "tsc --build --clean",
    "lint": "eslint packages",
    "hooks:install": "git config core.hooksPath .githooks",
    "changeset": "changeset",
    "version-packages": "changeset version && npm install --package-lock-only",
    "release": "npm run build && changeset publish",
    "sync-protocol": "tsx scripts/sync-protocol.ts",
    "tui": "npm --workspace @a5c-ai/agent-mux-tui run dev",
    "amux": "node packages/cli/dist/index.js",
    "cli": "npm run build --silent && node packages/cli/dist/index.js",
    "link-check": "find docs -name '*.md' -print0 | xargs -0 npx markdown-link-check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "markdown-link-check": "^3.14.2",
    "tsx": "^4.20.6",
    "typescript": "^5.4",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/instrumentation-fs": "^0.33.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  }
}
