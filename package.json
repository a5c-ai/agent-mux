{
  "name": "@a5c-ai/agent-mux-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.9.0"
  },
  "workspaces": [
    "packages/core",
    "packages/adapters",
    "packages/cli",
    "packages/agent-mux",
    "packages/harness-mock"
  ],
  "scripts": {
    "build": "tsc --build packages/core && tsc --build packages/adapters && tsc --build packages/harness-mock && tsc --build packages/cli && tsc --build packages/agent-mux",
    "typecheck": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:coverage": "vitest run --coverage",
    "clean": "tsc --build --clean",
    "lint": "eslint packages",
    "hooks:install": "git config core.hooksPath .githooks",
    "changeset": "changeset",
    "version-packages": "changeset version && npm install --package-lock-only",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20",
    "eslint": "^10.2.0",
    "typescript": "^5.4",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2"
  }
}
